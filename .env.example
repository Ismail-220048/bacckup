# ============================================================
# CivicTrack — Environment Variables EXAMPLE
# ============================================================
# Copy this file to .env and fill in your real values.
# The .env file is in .gitignore and should NEVER be committed.
# ============================================================

# ── MongoDB ──────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=civictrack

# ── Default Seed Credentials ────────────────────────────────
ADMIN_EMAIL=admin@civictrack.com
ADMIN_PASSWORD=your_admin_password_here
OFFICER_EMAIL=officer@civictrack.com
OFFICER_PASSWORD=your_officer_password_here

# ── Google OAuth ─────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_google_client_secret

# ── Twilio ───────────────────────────────────────────────────
# Get from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1415XXXXXXX

# ── SMTP / PHPMailer ─────────────────────────────────────────
# For Gmail, use an App Password (not your regular password):
#   https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_gmail_address@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_FROM_EMAIL=your_gmail_address@gmail.com
SMTP_FROM_NAME=CivicTrack Admin
